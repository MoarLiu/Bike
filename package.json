{
  "name": "bike",
  "version": "1.3.2",
  "private": true,
  "description": "Bike is a local-first outline note and mind map app with optional iCloud Drive backup.",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "auth:hash": "node scripts/hash-password.mjs",
    "icon:win": "node scripts/create-windows-icon.mjs",
    "mcp:bike": "node mcp/bike-server.mjs",
    "mcp:test": "node --test mcp/*.test.mjs",
    "mcp:smoke": "node mcp/bike-server.smoke.mjs",
    "serve:auth": "node server/auth-server.mjs",
    "start:web": "npm run build && npm run serve:auth",
    "electron:dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "electron:start": "vite build && electron .",
    "electron:test": "node --test electron/*.test.mjs",
    "electron:dist:mac": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --arm64",
    "electron:dist:win": "npm run build && electron-builder --win zip --x64"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "lucide-react": "^0.468.0",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.5.4",
    "vite": "^8.0.16",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.bike.app",
    "productName": "Bike",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "mcp/bike-core.mjs",
      "mcp/bike-server.mjs",
      "package.json"
    ],
    "afterPack": "scripts/after-pack.cjs",
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": null
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
